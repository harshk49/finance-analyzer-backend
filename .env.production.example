# =====================================================
# AI Personal Finance Analyzer — Production Environment
# =====================================================
# These values should be set in Azure App Service
# Configuration > Application Settings, NOT committed
# to git. This file is for documentation only.
# =====================================================

# ── PostgreSQL (Azure Database for PostgreSQL) ──────
POSTGRES_USER=financeadmin
POSTGRES_PASSWORD=<from-azure-portal>
POSTGRES_DB=finance_analyzer
POSTGRES_HOST=<your-server>.postgres.database.azure.com
POSTGRES_PORT=5432

# ── Database URLs ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db>?ssl=require
DATABASE_URL_SYNC=postgresql://<user>:<password>@<host>:5432/<db>?ssl=require

# ── Security ────────────────────────────────────────
SECRET_KEY=<generate-with-openssl-rand-hex-32>
SESSION_EXPIRY_HOURS=24

# ── Upload ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── CORS (your frontend URL) ───────────────────────
ALLOWED_ORIGINS=https://your-frontend.azurestaticapps.net

# ── App ─────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=WARNING
